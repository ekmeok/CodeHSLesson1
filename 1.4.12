//Use loops to put out the fires by painting them CYAN.
move();
move();
while (colorIs(Color.red)) {
    paint(Color.cyan);
    move();
}
move();
turnLeft();
move();
turnLeft();
while (colorIs(Color.red)) {
    paint(Color.cyan);
    move();
}
move();
turnRight();
move();
turnRight();
while (colorIs(Color.red)) {
    paint(Color.cyan);
    move();
}
